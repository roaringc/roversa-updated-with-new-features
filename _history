3.org/1999/xhtml\" no_return_value=\"true\"></mutation></block></statement><next><block type=\"controls_if\"><value name=\"IF0\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_operation\"><field name=\"OP\">OR</field><value name=\"A\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_operation\"><field name=\"OP\">OR</field><value name=\"A\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_compare\"><field name=\"OP\">LTE</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"h4QvX~NHMK[eEHs528~^\">health</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></value><value name=\"B\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_compare\"><field name=\"OP\">LTE</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"i9x$30cyHO7BDzWMI87E\">lifespan</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></value></block></value><value name=\"B\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_operation\"><field name=\"OP\">AND</field><value name=\"A\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_compare\"><field name=\"OP\">LTE</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"bhI~H.w4V`tb$hSu1l1_\">energy</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></value><value name=\"B\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_compare\"><field name=\"OP\">LTE</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"4n0)=7lWhx)[g8tk~|=7\">satiation</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></value></block></value></block></value><statement name=\"DO0\"><block type=\"variables_set\"><field name=\"VAR\" id=\"u)ricP6ZT;kB*4R{#.F3\">isDead</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></block></value><next><block type=\"function_call\"><mutation name=\"animDeath\" functionid=\"_;pE4i}LY8Neq6]_|`tx\"></mutation><next><block type=\"music_playable_play\"><field name=\"playbackMode\">music.PlaybackMode.UntilDone</field><value name=\"toPlay\"><shadow type=\"music_string_playable\"></shadow><block type=\"soundExpression_builtinPlayableSoundEffect\"><field name=\"soundExpression\">soundExpression.sad</field></block></value><next><block type=\"basic_show_icon\"><field name=\"i\">IconNames.Skull</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">1000</field></shadow></value><next><block type=\"device_print_message\"><value name=\"text\"><shadow type=\"text\"><field name=\"TEXT\">GAME OVER</field></shadow></value><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">300</field></shadow></value><next><block type=\"device_print_message\"><value name=\"text\"><shadow type=\"text\"><field name=\"TEXT\">AGE:</field></shadow></value><next><block type=\"device_show_number\"><value name=\"number\"><block type=\"variables_get\"><field name=\"VAR\" id=\"o}3(}2CL[3rI8qr/,VVz\">age</field></block></value><next><block type=\"device_print_message\"><value name=\"text\"><shadow type=\"text\"><field name=\"TEXT\">WT:</field></shadow></value><next><block type=\"device_show_number\"><value name=\"number\"><block type=\"variables_get\"><field name=\"VAR\" id=\"K{)[NGfg#Zw$bVSoXC$k\">weight</field></block></value><next><block type=\"device_print_message\"><value name=\"text\"><shadow type=\"text\"><field name=\"TEXT\">PHONE:</field></shadow></value><next><block type=\"device_show_number\"><value name=\"number\"><block type=\"variables_get\"><field name=\"VAR\" id=\"D#Sf7HD*th0]9lK%dLRg\">phoneTime</field></block></value><next><block type=\"device_print_message\"><value name=\"text\"><shadow type=\"text\"><field name=\"TEXT\">A+B RESTART</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></next></block></statement></block></xml>","main.ts":"/**\n * RoversAIgotchi v2 — with movement animations\n * \n * BUTTON MAP (Roversa pins):\n * \n * P8  = Phone (Menu button)\n * \n * P5  = Study (Play button)\n * \n * P9  = Play  (Pause button)\n * \n * P13 = Sleep (Forward button)\n * \n * P14 = Feed  (Reverse button)\n * \n * P15 = Exercise (Right button)\n * \n * P16 = Clean (Left button)\n * \n * ============================================================\n */\n// guard so animations don't stack\n// ============================================================\n// HELPERS\n// ============================================================\nfunction clamp (val: number) {\n    return Math.max(0, Math.min(100, val))\n}\n// Sad shuffle — used when stats are low or phone penalties hit\nfunction animSad () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    roversa.backward()\n    basic.pause(300)\n    roversa.stop()\n    basic.pause(100)\n    roversa.backward()\n    basic.pause(200)\n    roversa.stop()\n    isMoving = false\n}\n// Excited spin — used when phone gives a reward (dopamine hit)\nfunction animExcited () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    roversa.turnRight(360)\n    basic.pause(600)\n    roversa.stop()\n    isMoving = false\n}\n// ============================================================\n// BUTTON A — show face\n// ============================================================\ninput.onButtonPressed(Button.A, function () {\n    updateFace()\n    basic.pause(1000)\n})\n\n// Sleep rock — gentle back and forth, used when sleeping\nfunction animSleep () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    roversa.driveForwards(20)\n    basic.pause(400)\n    roversa.driveBackwards(20)\n    basic.pause(400)\n    roversa.stop()\n    isMoving = false\n}\n// ============================================================\n// CLEAN — P16 (Left button)\n// ============================================================\nroversa.onEvent(RoversaPin.P16, RoversaEvent.Click, function () {\n    if (isDead) {\n        return\n    }\n    health += 10\n    happiness += Math.idiv(5 * otherDampen, 10)\n    energy += 0 - 5\n    satiation += 0 - 5\n    weight += 0 - 1\n    weight = clampWeight(weight)\n    updateAlgorithm(false)\n    music.play(music.builtinPlayableSoundEffect(soundExpression.giggle), music.PlaybackMode.InBackground)\n    animHappy()\n    basic.showString(\"CLEAN\")\n})\n// Algorithm notification shake — urgent, jittery\nfunction animNotification () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    roversa.turnLeft(15)\n    basic.pause(100)\n    roversa.turnRight(30)\n    basic.pause(100)\n    roversa.turnLeft(30)\n    basic.pause(100)\n    roversa.turnRight(15)\n    basic.pause(100)\n    roversa.stop()\n    isMoving = false\n}\nfunction suggestAction () {\n    if (energy < 30) {\n        basic.showString(\"TRY SLEEP\")\n    } else if (satiation < 30) {\n        basic.showString(\"EAT FOOD\")\n    } else if (social < 30) {\n        basic.showString(\"CALL FRIEND\")\n    } else if (happiness < 30) {\n        basic.showString(\"PLAY\")\n    } else if (health < 30) {\n        basic.showString(\"EXERCISE\")\n    } else if (weight > 65) {\n        basic.showString(\"EXERCISE\")\n    } else if (weight < 30) {\n        basic.showString(\"EAT MORE\")\n    } else if (phoneTime > 8) {\n        basic.showString(\"TAKE BREAK\")\n    }\n}\n// ============================================================\n// FACE + SUGGEST\n// ============================================================\nfunction updateFace () {\n    if (isDead) {\n        basic.showIcon(IconNames.Skull)\n        return\n    }\n    if (health < 20) {\n        basic.showIcon(IconNames.Skull)\n    } else if (energy < 25) {\n        basic.showIcon(IconNames.Asleep)\n    } else if (happiness < 30) {\n        basic.showIcon(IconNames.Sad)\n    } else if (social < 30) {\n        basic.showIcon(IconNames.Confused)\n    } else if (weight > 65) {\n        basic.showIcon(IconNames.Surprised)\n    } else {\n        basic.showIcon(IconNames.Happy)\n    }\n}\n// Happy wiggle — used when feeding, playing, cleaning\nfunction animHappy () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    roversa.turnRight(30)\n    basic.pause(200)\n    roversa.turnLeft(30)\n    basic.pause(200)\n    roversa.turnRight(30)\n    basic.pause(200)\n    roversa.stop()\n    isMoving = false\n}\n// ============================================================\n// PLAY — P9 (Pause button)\n// ============================================================\nroversa.onEvent(RoversaPin.P9, RoversaEvent.Click, function () {\n    if (isDead) {\n        return\n    }\n    energy += 0 - 10\n    happiness += Math.idiv(10 * otherDampen, 10)\n    social += Math.idiv(10 * otherDampen, 10)\n    satiation += 0 - 5\n    updateAlgorithm(false)\n    music.play(music.builtinPlayableSoundEffect(soundExpression.happy), music.PlaybackMode.InBackground)\n    animHappy()\n    basic.showIcon(IconNames.Heart)\n    basic.pause(300)\n    basic.showString(\"PLAY\")\n})\n// Study pace — slow left-right drift, thinking\nfunction animStudy () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    roversa.turnLeft(20)\n    basic.pause(300)\n    roversa.turnRight(40)\n    basic.pause(300)\n    roversa.turnLeft(20)\n    basic.pause(300)\n    roversa.stop()\n    isMoving = false\n}\n// ============================================================\n// SLEEP — P13 (Forward button)\n// ============================================================\nroversa.onEvent(RoversaPin.P13, RoversaEvent.Click, function () {\n    if (isDead) {\n        return\n    }\n    energy += 20\n    happiness += Math.idiv(5 * otherDampen, 10)\n    health += 5\n    satiation += 0 - 10\n    weight += 0 - 1\n    weight = clampWeight(weight)\n    updateAlgorithm(false)\n    music.play(music.builtinPlayableSoundEffect(soundExpression.yawn), music.PlaybackMode.InBackground)\n    animSleep()\n    basic.showIcon(IconNames.Asleep)\n    basic.pause(300)\n    basic.showString(\"SLEEP\")\n})\n// Idle wander — subtle movement so the pet feels alive between actions\n// Called from the forever loop occasionally\nfunction animIdle () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    r = Math.randomRange(0, 3)\n    if (r == 0) {\n        roversa.turnLeft(15)\n        basic.pause(200)\n        roversa.stop()\n    } else if (r == 1) {\n        roversa.turnRight(15)\n        basic.pause(200)\n        roversa.stop()\n    } else if (r == 2) {\n        roversa.driveForwards(10)\n        basic.pause(150)\n        roversa.stop()\n    }\n    // r == 3: stay still — pet is resting\n    isMoving = false\n}\nfunction clampWeight (val: number) {\n    return Math.max(10, Math.min(120, val))\n}\n// Exercise burst — forward, spin, back\nfunction animExercise () {\n    if (isMoving) {\n        return\n    }\n    isMoving = true\n    roversa.driveForwards(60)\n    basic.pause(500)\n    roversa.turnLeft(180)\n    basic.pause(400)\n    roversa.driveForwards(60)\n    basic.pause(500)\n    roversa.turnLeft(180)\n    basic.pause(400)\n    roversa.stop()\n    isMoving = false\n}\n// ============================================================\n// DEATH\n// ============================================================\nfunction checkDeath () {\n    if (isDead) {\n        return\n    }\n    if (health <= 0 || lifespan <= 0 || energy <= 0 && satiation <= 0) {\n        isDead = true\n        animDeath()\n        music.play(music.builtinPlayableSoundEffect(soundExpression.sad), music.PlaybackMode.UntilDone)\n        basic.showIcon(IconNames.Skull)\n        basic.pause(1000)\n        basic.showString(\"GAME OVER\")\n        basic.pause(300)\n        basic.showString(\"AGE:\")\n        basic.showNumber(age)\n        basic.showString(\"WT:\")\n        basic.showNumber(weight)\n        basic.showString(\"PHONE:\")\n        basic.showNumber(phoneTime)\n        basic.showString(\"A+B RESTART\")\n    }\n}\n// ============================================================\n// RESTART — press A + B together\n// ============================================================\ninput.onButtonPressed(Button.AB, function () {\n    if (!(isDead)) {\n        return\n    }\n    energy = 70\n    happiness = 70\n    health = 70\n    satiation = 70\n    social = 70\n    weight = 50\n    age = 0\n    lifespan = 100\n    phoneTime = 0\n    algoScore = 0\n    algoPhase = 0\n    phoneBonusMulti = 10\n    otherDampen = 10\n    isDead = false\n    isMoving = false\n    animHappy()\n    basic.showIcon(IconNames.Happy)\n    basic.showString(\"NEW PET!\")\n})\n// ============================================================\n// BUTTON B — cycle through stats\n// ============================================================\ninput.onButtonPressed(Button.B, function () {\n    if (isDead) {\n        return\n    }\n    // Array of stat labels (abbreviated)\n    labels = [\n    \"ENG\",\n    \"HAP\",\n    \"HLT\",\n    \"SAT\",\n    \"SOC\",\n    \"AGE\",\n    \"WGT\",\n    \"LIF\"\n    ]\n    // Array of corresponding values\n    values = [\n    energy,\n    happiness,\n    health,\n    satiation,\n    social,\n    age,\n    weight,\n    lifespan\n    ]\n    // Loop through all stats automatically\n    for (let i = 0; i <= labels.length - 1; i++) {\n        basic.showString(\"\" + (labels[i]))\n        basic.showNumber(values[i])\n        basic.pause(300)\n    }\n})\n// ============================================================\n// FEED — P14 (Reverse button)\n// Overeating: satiation > 85 causes extra weight + health penalty\n// ============================================================\nroversa.onEvent(RoversaPin.P14, RoversaEvent.Click, function () {\n    if (isDead) {\n        return\n    }\n    health += 5\n    energy += 10\n    weightGain = 2\n    if (satiation > 85) {\n        weightGain = 4\n        health += 0 - 3\n        animSad()\n        basic.showString(\"TOO FULL\")\n    } else {\n        satiation += 15\n        animHappy()\n        basic.showIcon(IconNames.Happy)\n        basic.pause(300)\n        basic.showString(\"EAT\")\n    }\n    weight += weightGain\n    weight = clampWeight(weight)\n    updateAlgorithm(false)\n    music.play(music.builtinPlayableSoundEffect(soundExpression.spring), music.PlaybackMode.InBackground)\n})\n// ============================================================\n// ALGORITHM — hidden engagement tracking\n// ============================================================\nfunction updateAlgorithm (isPhone: boolean) {\n    if (isPhone) {\n        algoScore += 3\n        if (algoPhase == 0 && algoScore >= 9) {\n            algoPhase = 1\n            phoneBonusMulti = 16\n            otherDampen = 8\n            basic.showString(\"...\")\n            animNotification()\n        }\n        if (algoPhase == 1 && algoScore >= 21) {\n            algoPhase = 2\n            phoneBonusMulti = 6\n            otherDampen = 5\n        }\n        if (algoScore >= 24 && algoPhase >= 2) {\n            basic.showString(\"ALGORITHM WATCHING\")\n            basic.pause(400)\n            basic.showString(\"SCORE:\")\n            basic.showNumber(algoScore)\n        }\n    } else {\n        algoScore += 1\n    }\n}\n// ============================================================\n// PHONE — P8 (Menu button)\n// Core algorithm teaching mechanic\n// ============================================================\nroversa.onEvent(RoversaPin.P8, RoversaEvent.Click, function () {\n    if (isDead) {\n        return\n    }\n    phoneTime += 1\n    // sedentary\n    weight += 1\n    updateAlgorithm(true)\n    if (phoneTime <= 5) {\n        moodBoost = Math.idiv(phoneBonusMulti * 5, 10)\n        happiness += moodBoost\n        // Algorithm phase 1: spin with excitement — feels great!\n        if (algoPhase >= 1) {\n            animExcited()\n        } else {\n            animHappy()\n        }\n        music.play(music.builtinPlayableSoundEffect(soundExpression.happy), music.PlaybackMode.InBackground)\n        basic.showIcon(IconNames.Heart)\n        basic.pause(300)\n    } else if (phoneTime <= 10) {\n        happiness += 0 - 5\n        energy += 0 - 5\n        health += 0 - 3\n        social += 0 - 5\n        lifespan += 0 - 1\n        animSad()\n        music.play(music.builtinPlayableSoundEffect(soundExpression.sad), music.PlaybackMode.InBackground)\n        basic.showIcon(IconNames.Sad)\n        basic.pause(300)\n    } else {\n        happiness += 0 - 10\n        energy += 0 - 10\n        health += 0 - 5\n        social += 0 - 10\n        lifespan += 0 - 2\n        animSad()\n        music.play(music.builtinPlayableSoundEffect(soundExpression.sad), music.PlaybackMode.InBackground)\n        basic.showString(\"TOO MUCH PHONE\")\n    }\n    lifespan = clamp(lifespan)\n    basic.showString(\"PHONE\")\n    checkDeath()\n})\n// ============================================================\n// STUDY — P5 (Play button)\n// ============================================================\nroversa.onEvent(RoversaPin.P5, RoversaEvent.Click, function () {\n    if (isDead) {\n        return\n    }\n    energy += 0 - 5\n    satiation += 0 - 5\n    happiness += 0 - 5\n    health += 5\n    updateAlgorithm(false)\n    music.play(music.builtinPlayableSoundEffect(soundExpression.soaring), music.PlaybackMode.InBackground)\n    animStudy()\n    basic.showString(\"STUDY\")\n})\n// Death spin — dramatic, used once on death\nfunction animDeath () {\n    isMoving = true\n    roversa.turnRight(720)\n    basic.pause(1200)\n    roversa.backward()\n    basic.pause(500)\n    roversa.stop()\n    isMoving = false\n}\n// ============================================================\n// EXERCISE — P15 (Right button)\n// ============================================================\nroversa.onEvent(RoversaPin.P15, RoversaEvent.Click, function () {\n    if (isDead) {\n        return\n    }\n    energy += 0 - 10\n    satiation += 0 - 10\n    health += 10\n    weight += 0 - 3\n    lifespan += 1\n    lifespan = clamp(lifespan)\n    weight = clampWeight(weight)\n    updateAlgorithm(false)\n    music.play(music.builtinPlayableSoundEffect(soundExpression.mysterious), music.PlaybackMode.InBackground)\n    animExercise()\n    basic.showString(\"EXE\")\n    checkDeath()\n})\nlet drain = 0\nlet ageFactor = 0\nlet moodBoost = 0\nlet weightGain = 0\nlet values: number[] = []\nlet labels: string[] = []\nlet algoPhase = 0\nlet algoScore = 0\nlet age = 0\nlet r = 0\nlet phoneTime = 0\nlet isDead = false\nlet isMoving = false\nlet otherDampen = 0\nlet phoneBonusMulti = 0\nlet lifespan = 0\nlet weight = 0\nlet social = 0\nlet satiation = 0\nlet health = 0\nlet happiness = 0\nlet energy = 0\nlet statIndex = 0\n// ---------- STATS ----------\nenergy = 70\nhappiness = 70\nhealth = 70\nsatiation = 70\nsocial = 70\n// ---------- BODY ----------\n// kg\nweight = 50\n// days (1 tick = 1 day)\n// hits 0 = death\nlifespan = 100\nbasic.pause(500)\n\nbasic.showIcon(IconNames.Happy)\nmusic.play(music.builtinPlayableSoundEffect(soundExpression.happy), music.PlaybackMode.InBackground)\n\nbasic.pause(800)\n\nupdateFace()\n// 0=learning  1=targeting  2=hooked\n// x10 for integer math — actual multiplier is /10\nphoneBonusMulti = 10\n// 10=full gain, 8=dampened, 5=heavily dampened\notherDampen = 10\n// ============================================================\n// FOREVER LOOP — 15 second tick = 1 day\n// ============================================================\nbasic.forever(function () {\n    basic.pause(15000)\n    if (isDead) {\n        return\n    }\n    age += 1\n    // Faster decay after day 30\n    ageFactor = 1\n    if (age > 30) {\n        ageFactor = 2\n    }\n    energy += 0 - 2 * ageFactor\n    satiation += 0 - 3 * ageFactor\n    social += 0 - 1 * ageFactor\n    // Weight drift\n    if (satiation > 70) {\n        weight += 1\n    }\n    if (satiation < 20) {\n        weight += 0 - 1\n    }\n    weight = clampWeight(weight)\n    // Lifespan drain\n    drain = 1\n    if (health < 30) {\n        drain += 2\n    }\n    if (weight > 65) {\n        drain += 1\n    }\n    if (phoneTime > 8) {\n        drain += 1\n    }\n    lifespan += 0 - drain\n    lifespan = clamp(lifespan)\n    // Clamp all stats\n    energy = clamp(energy)\n    happiness = clamp(happiness)\n    health = clamp(health)\n    satiation = clamp(satiation)\n    social = clamp(social)\n    // Algorithm notification jitter in phase 1+\n    if (algoPhase >= 1) {\n        animNotification()\n        basic.showString(\"NOTIF!\")\n        basic.pause(300)\n    } else {\n        // Idle wander so the pet feels alive\n        animIdle()\n    }\n    // Show face then suggest\n    updateFace()\n    basic.pause(800)\n    suggestAction()\n    checkDeath()\n})\n","README.md":"","main.py":"# Clean\n\ndef my_function():\n    global health, happiness, energy, satiation\n    health += 10\n    happiness += 5\n    energy += 0 - 5\n    satiation += 0 - 5\n    music.play(music.builtin_playable_sound_effect(soundExpression.giggle),\n        music.PlaybackMode.IN_BACKGROUND)\n    basic.show_string(\"CLEAN\")\nroversa.on_event(RoversaPin.P16, RoversaEvent.CLICK, my_function)\n\ndef suggestAction():\n    if energy < 30:\n        basic.show_string(\"TRY SLEEP\")\n    elif satiation < 30:\n        basic.show_string(\"EAT FOOD\")\n    elif social < 30:\n        basic.show_string(\"CALL FRIEND\")\n    elif happiness < 30:\n        basic.show_string(\"PLAY\")\n    elif health < 30:\n        basic.show_string(\"EXERCISE\")\n    elif phoneTime > 8:\n        basic.show_string(\"TAKE BREAK\")\n# Play\n\ndef my_function2():\n    global energy, happiness, social, satiation\n    energy += 0 - 10\n    happiness += 10\n    social += 10\n    satiation += 0 - 5\n    music.play(music.builtin_playable_sound_effect(soundExpression.happy),\n        music.PlaybackMode.IN_BACKGROUND)\n    basic.show_icon(IconNames.HEART)\n    basic.pause(500)\n    basic.show_string(\"PLAY\")\nroversa.on_event(RoversaPin.P9, RoversaEvent.CLICK, my_function2)\n\ndef clampStats():\n    global energy, happiness, health, satiation, social\n    energy = max(0, min(100, energy))\n    happiness = max(0, min(100, happiness))\n    health = max(0, min(100, health))\n    satiation = max(0, min(100, satiation))\n    social = max(0, min(100, social))\n# Sleep\n\ndef my_function3():\n    global energy, happiness, health, satiation\n    energy += 20\n    happiness += 5\n    health += 5\n    satiation += 0 - 10\n    music.play(music.builtin_playable_sound_effect(soundExpression.yawn),\n        music.PlaybackMode.IN_BACKGROUND)\n    basic.show_icon(IconNames.ASLEEP)\n    basic.pause(500)\n    basic.show_string(\"SLEEP\")\nroversa.on_event(RoversaPin.P13, RoversaEvent.CLICK, my_function3)\n\ndef on_button_pressed_b():\n    global statIndex\n    statIndex += 1\n    if statIndex == 1:\n        basic.show_string(\"E\")\n        basic.show_number(energy)\n    elif statIndex == 2:\n        basic.show_string(\"HAP\")\n        basic.show_number(happiness)\n    elif statIndex == 3:\n        basic.show_string(\"HLT\")\n        basic.show_number(health)\n    elif statIndex == 4:\n        basic.show_string(\"SAT\")\n        basic.show_number(satiation)\n    elif statIndex == 5:\n        basic.show_string(\"SOC\")\n        basic.show_number(social)\n        statIndex = 0\ninput.on_button_pressed(Button.B, on_button_pressed_b)\n\n# Feed\n\ndef my_function4():\n    global health, satiation, energy\n    health += 5\n    satiation += 15\n    energy += 10\n    music.play(music.builtin_playable_sound_effect(soundExpression.spring),\n        music.PlaybackMode.IN_BACKGROUND)\n    basic.show_icon(IconNames.HAPPY)\n    basic.pause(500)\n    basic.show_string(\"EAT\")\nroversa.on_event(RoversaPin.P14, RoversaEvent.CLICK, my_function4)\n\n# Phone\n\ndef my_function5():\n    global phoneTime, happiness, energy, health, social\n    phoneTime += 1\n    if phoneTime <= 5:\n        happiness += 5\n    else:\n        if phoneTime > 10:\n            basic.show_string(\"TOO MUCH PHONE\")\n            happiness += 0 - 5\n            energy += 0 - 5\n            health += 0 - 5\n            social += 0 - 5\n        happiness += 0 - 5\n        energy += 0 - 5\n        health += 0 - 5\n        social += 0 - 5\n    music.play(music.builtin_playable_sound_effect(soundExpression.sad),\n        music.PlaybackMode.IN_BACKGROUND)\n    basic.show_icon(IconNames.SAD)\n    basic.pause(500)\n    basic.show_string(\"PHONE\")\nroversa.on_event(RoversaPin.P8, RoversaEvent.CLICK, my_function5)\n\n# Study\n\ndef my_function6():\n    global energy, satiation, happiness, health\n    energy += 0 - 5\n    satiation += 0 - 5\n    happiness += 0 - 5\n    health += 5\n    music.play(music.builtin_playable_sound_effect(soundExpression.soaring),\n        music.PlaybackMode.IN_BACKGROUND)\n    basic.show_string(\"STUDY\")\nroversa.on_event(RoversaPin.P5, RoversaEvent.CLICK, my_function6)\n\n# Exercise\n\ndef my_function7():\n    global energy, satiation, health\n    energy += 0 - 10\n    satiation += 0 - 10\n    health += 10\n    music.play(music.builtin_playable_sound_effect(soundExpression.mysterious),\n        music.PlaybackMode.IN_BACKGROUND)\n    basic.show_string(\"EXE\")\nroversa.on_event(RoversaPin.P15, RoversaEvent.CLICK, my_function7)\n\nstatIndex = 0\nphoneTime = 0\nsocial = 0\nsatiation = 0\nhealth = 0\nhappiness = 0\nenergy = 0\nenergy = 70\nhappiness = 70\nhealth = 70\nsatiation = 70\nsocial = 70\n\ndef on_forever():\n    global energy, satiation, social\n    # every 15 seconds\n    basic.pause(15000)\n    energy += -2\n    satiation += -3\n    social += -1\n    if health < 30:\n        basic.show_icon(IconNames.SKULL)\n    elif energy < 25:\n        basic.show_icon(IconNames.ASLEEP)\n    elif happiness < 30:\n        basic.show_icon(IconNames.SAD)\n    elif social < 30:\n        basic.show_icon(IconNames.CONFUSED)\n    else:\n        basic.show_icon(IconNames.HAPPY)\n    suggestAction()\nbasic.forever(on_forever)\n","pxt.json":"{\n    \"name\": \"Roversa Updated with New Features\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"roversa\": \"github:eb8ga/pxt-roversa-2#v1.0.28\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"stable8.0\",\n        \"tag\": \"v8.0.18\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/ec67ee1ad9a7c41ee95376e7577127b32d4d233a\",\n        \"target\": \"8.0.18\",\n        \"pxt\": \"12.0.16\"\n    },\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1776182613554,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"t-dD-0GVejTSv|@oO1f}\">isMoving</variable><varia